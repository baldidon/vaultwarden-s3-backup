# S3 Configuration (all required together, or omit entirely)
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=my-backups
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_PATH_PREFIX=vaultwarden-backups

# Local backup path (omit to disable local backups)
LOCAL_BACKUP_PATH=/backups

# Encryption (required)
ENCRYPTION_PASSWORD=change-me-to-a-strong-password

# Vaultwarden
VAULTWARDEN_DATA_PATH=/data

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Cron schedule (used by Ofelia)
BACKUP_CRON=0 3 * * *

# Temp directory
TMP_DIR=/tmp/vw-backup

# Notifications (optional)
NOTIFY_WEBHOOK_URL=https://ntfy.sh/your-topic
# NOTIFY_ON_SUCCESS=true
# NOTIFY_ON_FAILURE=true
